---
import TimeFormat from './TimeFormat.astro';
type Props = {
  logo: string;
  title: string;
  description: string;
  company: string;
  location: string;
  startDate: string;
  endDate: string;
};

const { logo, title, description, company, location, startDate, endDate } =
  Astro.props;
---

<article>
  <div class='flex items-start justify-start gap-3'>
    <div class='h-auto'>
      <img src={logo} alt='logo' class='w-12 h-12 m-0' />
    </div>
    <div class='flex flex-col'>
      <h3 class='text-base font-semibold underline'>{title}</h3>
      <span class='info flex flex-wrap gap-1 leading-3'>
        <span>{company}</span>
        <span> -</span>
        <span>{location}</span>
      </span>

      <span class='info'>
        <TimeFormat
          date={startDate}
          format={{ month: 'short', year: 'numeric' }}
        />
        <span> -</span>
        <TimeFormat
          date={endDate}
          format={{ month: 'short', year: 'numeric' }}
        />
      </span>
    </div>
  </div>

  <p class='text-sm line-clamp-3'>
    {description}
  </p>
</article>

<style>
  article {
    @apply p-4;
  }
  .info {
    @apply text-sm opacity-40 m-0 p-0;
  }
</style>
