---
type Props = {
  date: Date | string;
  class?: string;
  format?: Intl.DateTimeFormatOptions;
};

let {
  date,
  class: classes,
  format = {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  },
} = Astro.props;
date = typeof date === 'string' ? new Date(date) : date;
---

<time datetime={date.toISOString()} class={classes}>
  {date.toLocaleDateString('en-us', format)}
</time>

<style>
  time {
    @apply text-current text-sm;
  }
</style>
